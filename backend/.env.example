# ─────────────────────────────────────────────────────────────────────────────
#  backend/.env.example  —  copy to .env and fill in real values
#  cp .env.example .env
#  ⚠  Never commit the real .env file (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (Agent 3 & Agent 4 use Groq) ────────────────────────────────
#  Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Allowed frontend origin(s) for CORS ──────────────────────────────────────
#  Comma-separated list.  In production, set this to your Vercel domain.
#  Example:  https://quote-agents.vercel.app
#  Leave blank to use the defaults (localhost:3000).
FRONTEND_ORIGINS=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
