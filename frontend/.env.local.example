# ─────────────────────────────────────────────────────────────────────────────
#  frontend/.env.local.example  —  copy to .env.local and fill in real values
#  cp .env.local.example .env.local
#  ⚠  Never commit the real .env.local file (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────────────────
#  Local development:   http://localhost:8001
#  Production (Docker):  https://your-backend-domain.com
#  Production (Railway): https://quote-agents-backend-production.up.railway.app
#
#  The NEXT_PUBLIC_ prefix makes this variable available in browser code.
NEXT_PUBLIC_API_URL=http://localhost:8001
