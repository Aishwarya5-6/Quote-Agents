    "Driving_Exp",
    "Driver_Age",
    "Annual_Miles",
    "Veh_Usage_Business",
    "Veh_Usage_Commute",
    "Veh_Usage_Pleasure"
  ],
  "shap_method": "TreeExplainer (interventional) on base XGBClassifier",
  "artifacts": [
    "calibrated_risk_profiler.pkl",
    "shap_explainer.pkl",
    "ohe_encoder.pkl",
    "label_encoder.pkl",
    "feature_names.pkl"
